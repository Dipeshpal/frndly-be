DATABASE_URL=postgresql+asyncpg://frndly:frndly@localhost:5437/frndly
JWT_SECRET_KEY=replace_me_with_a_strong_random_secret
# Dedicated Fernet key for vault. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, derived from JWT_SECRET_KEY — changing that key will break all existing secrets!
VAULT_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
SUPABASE_URL=
SUPABASE_ANON_KEY=
