{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "runtime": "python@3.11",
  "functions": {
    "api/index.py": {
      "runtime": "python@3.11",
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET_KEY": "@jwt_secret_key",
    "JWT_ALGORITHM": "HS256",
    "ACCESS_TOKEN_EXPIRE_MINUTES": "1440",
    "ALLOWED_ORIGINS": "@allowed_origins"
  }
}
